# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────
# Replace with your MongoDB Compass connection string
MONGO_URI=mongodb://127.0.0.1:27017/pgc_sgcms


# ── JWT Secrets ───────────────────────────────────────────
# IMPORTANT: Replace with long random strings in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex_access
JWT_REFRESH_SECRET=replace_with_64_char_random_hex_refresh

# ── CORS ──────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
